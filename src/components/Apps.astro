---
const apps = [
  { name: 'Doppio', badge: 'BETA',           tags: ['iOS', 'Swift', 'Brew architecture'], image: '/doppio-screenshot.png'  },
  { name: 'Raipe',  badge: 'IN DEVELOPMENT', tags: ['iOS', 'Swift', 'Client work'],       image: '/raipe-screenshot.png'   },
];
---

<section class="apps" id="apps">
  <div class="section-inner">
    <h2 class="section-title">
      <span class="num">02</span>
      <span data-i18n="apps.title">Apps</span>
    </h2>

    <div class="apps-grid">
      {apps.map((app, i) => (
        <div class="app-card">
          <div class="app-image">
            <div class="image-placeholder">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
            </div>
          </div>
          <div class="app-body">
            <div class="app-header">
              <span class="app-name">{app.name}</span>
              <span class="app-badge">{app.badge}</span>
            </div>
            <p class="app-description" data-i18n={`apps.entries.${i}.description`}></p>
            <div class="app-tags">
              {app.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .apps {
    position: relative;
    z-index: 1;
    padding: 6rem 2.5rem;
    border-top: 1px solid var(--border);
  }

  .section-inner { max-width: 900px; margin: 0 auto; }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    color: var(--text);
    margin-bottom: 3.5rem;
    line-height: 1;
  }

  .num {
    color: var(--accent);
    margin-right: 0.5rem;
    font-size: 0.5em;
    vertical-align: middle;
  }

  .apps-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .app-card {
    border: 1px dashed var(--border);
    border-radius: 4px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .app-card:hover { border-color: rgba(232, 92, 13, 0.4); }

  .app-image {
    aspect-ratio: 16/9;
    background: rgba(255,255,255,0.03);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .image-placeholder { color: var(--text-dim); }

  .app-body { padding: 1.25rem; }

  .app-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .app-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text);
  }

  .app-badge {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 3px;
    padding: 0.15rem 0.4rem;
  }

  .app-description {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--text);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .app-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.2rem 0.5rem;
  }

  @media (max-width: 600px) {
    .apps { padding: 4rem 1.25rem; }
    .apps-grid { grid-template-columns: 1fr; }
  }
</style>
