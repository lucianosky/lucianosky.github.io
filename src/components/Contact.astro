---
---

<div class="cv-banner">
  <div class="cv-inner">
    <div class="cv-text">
      <h3 data-i18n="cv.headline">The full trajectory, on paper.</h3>
      <p data-i18n="cv.subline">Forty years condensed into two pages.</p>
    </div>
    <a href="/LucianoSclovsky.En.pdf" class="btn-cv" download data-i18n="cv.button_en">DOWNLOAD CV (EN) ↓</a>
    <a href="/LucianoSclovsky.Pt.pdf" class="btn-cv" download data-i18n="cv.button_pt">DOWNLOAD CV (PT) ↓</a>
  </div>
</div>

<section class="contact" id="contact">
  <div class="section-inner">
    <h2 class="section-title">
      <span class="num">05</span>
      <span data-i18n="contact.title">Contact</span>
    </h2>

    <p class="contact-line" data-i18n="contact.line">
      Open to senior iOS and mobile architecture roles,
      remote or hybrid, anywhere on Earth.
    </p>

    <div class="contact-links">
      <a href="mailto:luciano@example.com" class="contact-btn">luciano@example.com</a>
      <a href="https://linkedin.com/in/lucianosky" class="contact-btn" target="_blank" rel="noopener">linkedin ↗</a>
      <a href="https://github.com/lucianosky" class="contact-btn" target="_blank" rel="noopener">github ↗</a>
    </div>
  </div>
</section>

<style>
  .cv-banner {
    position: relative;
    z-index: 1;
    background: linear-gradient(135deg, rgba(232, 92, 13, 0.08) 0%, transparent 60%);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 3.5rem 2.5rem;
  }

  .cv-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cv-text h3 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--text);
    margin-bottom: 0.35rem;
  }

  .cv-text p {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .btn-cv {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 0.85rem 1.75rem;
    border-radius: 2px;
    white-space: nowrap;
    transition: opacity 0.2s;
  }

  .btn-cv:hover { opacity: 0.85; }

  .contact {
    position: relative;
    z-index: 1;
    padding: 6rem 2.5rem;
  }

  .section-inner { max-width: 900px; margin: 0 auto; }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    color: var(--text);
    margin-bottom: 1.5rem;
    line-height: 1;
  }

  .num {
    color: var(--accent);
    margin-right: 0.5rem;
    font-size: 0.5em;
    vertical-align: middle;
  }

  .contact-line {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--text);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .contact-links { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .contact-btn {
    display: inline-block;
    border: 1px solid var(--border);
    padding: 0.6rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text);
    border-radius: 3px;
    transition: border-color 0.2s, color 0.2s;
  }

  .contact-btn:hover { border-color: var(--accent); color: var(--accent); }

  @media (max-width: 600px) {
    .cv-banner { padding: 2.5rem 1.25rem; }
    .cv-inner { flex-direction: column; align-items: flex-start; }
    .contact { padding: 4rem 1.25rem; }
  }
</style>
